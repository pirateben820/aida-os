# Copy to .env and fill in ONE of the free setup providers below.
# Only needed for first-boot setup — after that your local models take over.
#
# FREE (no credit card required):
#   Gemini      → https://aistudio.google.com/app/apikey
#   OpenRouter  → https://openrouter.ai/keys          (free models available)
#   Groq        → https://console.groq.com/keys
#   Cohere      → https://dashboard.cohere.com/api-keys
#
# PAID (optional, ~$0.001 for one setup session):
#   Anthropic   → https://console.anthropic.com/
#   OpenAI      → https://platform.openai.com/api-keys

# Uncomment the one you want to use:
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# COHERE_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Runtime
AIDAD_URL=http://127.0.0.1:8421
NATS_URL=nats://127.0.0.1:4222
OLLAMA_API_BASE=http://127.0.0.1:11434
